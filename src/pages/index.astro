---
import "../styles/global.css";

const projects = [
  {
    title: "Dev Dashboard",
    role: "Frontend Developer",
    desc: "Dashboard interactivo que consume la API de GitHub en tiempo real. Visualización de estadísticas, repositorios y actividad con gráficas, filtros y modo oscuro.",
    tech: ["React", "TypeScript", "Tailwind", "Next.js"],
    link: "https://github.com/alberto-lopz23/dev-dashboard",
    
  },
  {
    title: "Weather App",
    role: "Frontend Developer",
    desc: "Aplicación del clima con búsqueda por ciudad, pronóstico de 7 días y geolocalización. Consume la API de OpenWeatherMap con diseño responsive y animaciones según el clima.",
    tech: ["React", "TypeScript", "Tailwind", "OpenWeatherMap API"],
    link: "https://github.com/alberto-lopz23/weather-app",
    link2: "https://weather-app-seven-liart-39.vercel.app/",
  },
  {
    title: "TruckDOM",
    role: "Game Developer",
    desc: "Simulador de camiones en navegador construido desde cero con mundo procedural, zonas de ciudad, misiones de carga, tráfico y ciclo día/noche.",
    tech: ["JavaScript", "Three.js", "Canvas API"],
    link: "https://github.com/alberto-lopz23/truckdom",
  },
];

const skills = [
  "React",
  "Astro",
  "Next.js",
  "JavaScript (ES6+)",
  "TypeScript",
  "Node.js",
  "Tailwind CSS",
  "Git & GitHub",
];
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <link
      rel="shortcut icon"
      href="/src/assets/hombre.ico"
      type="image/x-icon"
    />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Alberto Lopez | Frontend Developer</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <nav class="navbar">
      <div class="nav-container">
        <a href="#" class="logo">Alberto <span>López</span></a>
        <ul class="nav-links">
          <li><a href="#projects">Proyectos</a></li>
          <li><a href="#about">Sobre mí</a></li>
          <li><a href="#skills">Stack</a></li>
          <li><a href="#contact" class="nav-contact">Contactar</a></li>
        </ul>
      </div>
    </nav>

    <main>
      <section id="hero">
        <div class="hero-glow"></div>
        <div class="container animate-fade">
          <span class="badge">Disponible para nuevos proyectos</span>
          <h1 class="hero-title">
            Transformo ideas en <br />
            <span>Interfaces de Alto Impacto</span>
          </h1>
          <p class="hero-subtitle">
            Soy Alberto, <strong>Frontend Developer</strong> especializado en crear
            experiencias web modernas, rápidas y accesibles utilizando el ecosistema
            de JavaScript.
          </p>
          <div class="btn-group">
            <a href="#projects" class="btn-primary">Ver Portafolio</a>
            <a
              href="https://www.linkedin.com/in/alberto-lopez-checo-294961271/"
              target="_blank"
              class="btn-secondary">LinkedIn</a
            >
          </div>
        </div>
      </section>

      <section id="projects" class="section-padding">
        <div class="container">
          <header class="section-header">
            <h2 class="section-title">Proyectos Destacados</h2>
            <div class="title-line"></div>
          </header>

          <div class="projects-grid">
            {
              projects.map((p) => (
                <article class="project-card">
                  <header>
                    <span class="project-role">{p.role}</span>
                    <h3>{p.title}</h3>
                  </header>
                  <p class="project-desc">{p.desc}</p>
                  <footer class="project-footer">
                    <div class="tech-stack">
                      {p.tech.map((t) => (
                        <span class="tech-tag">{t}</span>
                      ))}
                    </div>
                    <a href={p.link} target="_blank" class="project-link">
                      Ver Código
                    </a>
                    <a href={p.link2} target="_blank" class="project-link">
                      Ver Demo
                    </a>
                  </footer>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <section id="about" class="section-padding bg-darker">
        <div class="container grid-2-cols">
          <div class="about-text">
            <h2 class="section-title">Sobre mi enfoque</h2>
            <p>
              No solo escribo código; construyo productos digitales. Me enfoco
              en la <strong>optimización de rendimiento</strong>, la <strong
                >escalabilidad</strong
              > y una experiencia de usuario impecable.
            </p>
            <p>
              Mi objetivo es ayudar a empresas a destacar mediante interfaces
              que no solo se vean bien, sino que funcionen perfectamente en
              cualquier dispositivo.
            </p>
          </div>
          <div class="about-stats">
            <div class="stat-card">
              <h4>Astro & React</h4>
              <p>Especialización principal</p>
            </div>
          </div>
        </div>
      </section>

      <section id="skills" class="section-padding">
        <div class="container text-center">
          <h2 class="section-title">Tecnologías y herramientas</h2>
          <div class="skills-container">
            {skills.map((s) => <span class="skill-badge">{s}</span>)}
          </div>
        </div>
      </section>

      <section id="contact" class="section-padding">
        <div class="container contact-box">
          <h2 class="hero-title">¿Listo para escalar tu producto?</h2>
          <p class="hero-subtitle">
            Hablemos sobre cómo puedo aportar valor a tu equipo técnico.
          </p>
          <div class="btn-group-center">
            <a href="mailto:albertolopezcheco3@gmail.com" class="btn-primary"
              >Enviar Email</a
            >
            <a href="/public/cv/Cv-AlbertoLopez.pdf" download class="btn-secondary">
              Descargar CV
            </a>
          </div>
        </div>
      </section>
    </main>

    <footer class="main-footer">
      <p>© 2026 Alberto Lopez — Santo Domingo, RD</p>
      <div class="social-links">
        <a href="https://github.com/alberto-lopz23">Github</a>
        <a href="https://www.linkedin.com/in/alberto-lopez-checo-294961271/"
          >LinkedIn</a
        >
      </div>
    </footer>
  </body>
</html>
